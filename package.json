{
  "name": "knovant-deep-research",
  "version": "1.0.0",
  "description": "An AI-powered deep research desktop application",
  "author": "JuzerSaify <juzersaifuddinma@gmail.com>",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "cheerio": "^1.0.0-rc.12",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.knovant.research",
    "productName": "Knovant",
    "protocols": [
      {
        "name": "Knovant Deep Link",
        "schemes": [
          "knovant",
          "galaxy"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "JuzerSaify",
      "repo": "knovant"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  }
}
